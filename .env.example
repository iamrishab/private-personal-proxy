# Optional: override the Dynaconf environment (default | streamlit | testing).
# ENV_FOR_DYNACONF=default

# Optional: point to a non-default Ollama server.
# APP_OLLAMA__BASE_URL=http://localhost:11434

# Optional: override the tool-capable chat model served by Ollama.
# APP_LLM__MODEL=llama3.2:3b

# Optional: override the embedding model served by Ollama.
# APP_LLM__EMBEDDING_MODEL=nomic-embed-text:latest
